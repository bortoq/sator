#!/usr/bin/env bash
# sator — Search And TORrent
# v0.1 — multi-tracker search, filtering, qBittorrent integration

set -euo pipefail

VERSION="0.1"

# ─── Configuration ───────────────────────────────────────────────────────────
QB_URL="http://localhost:8090"
CACHE_DIR="${HOME}/.cache/sator"
WIKI_CACHE="${CACHE_DIR}/wikilang.json"
CURL_UA="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
CURL_BIN="curl"
[[ -x "${HOME}/bin/curl-impersonate-chrome" ]] && CURL_BIN="${HOME}/bin/curl-impersonate-chrome"

# ─── Language mapping ────────────────────────────────────────────────────────
# ISO 639-1 → English name
LANG_EN=(en:english ru:russian fr:french de:german it:italian
         es:spanish pt:portuguese nl:dutch pl:polish sv:swedish
         da:danish fi:finnish cs:czech hu:hungarian ro:romanian
         uk:ukrainian el:greek tr:turkish th:thai vi:vietnamese
         hi:hindi bn:bengali he:hebrew ar:arabic ja:japanese
         ko:korean zh:chinese no:norwegian id:indonesian ms:malay
         sr:serbian hr:croatian sk:slovak bg:bulgarian sl:slovenian
         lt:lithuanian lv:latvian et:estonian is:icelandic ga:irish
         cy:welsh mt:maltese sq:albanian mk:macedonian bs:bosnian
         ca:catalan gl:galician eu:basque la:latin)

declare -A LANG_NAMES
declare -A LANG_CODES
for entry in "${LANG_EN[@]}"; do
  code="${entry%%:*}"
  name="${entry#*:}"
  LANG_NAMES["$code"]="$name"
  LANG_CODES["$name"]="$code"
done

# ─── Helper functions ────────────────────────────────────────────────────────
err()   { echo "✖ $*" >&2; }
warn()  { echo "⚠ $*" >&2; }
info()  { echo "• $*" >&2; }

usage() {
  cat <<EOF
sator v${VERSION} — Search And TORrent

Usage:
  sator -f <file>              # Search queries from file (one per line)
  sator -s <string>            # Search by query string
  sator -f <file> -a           # Search + auto-add to qBittorrent
  sator -a <file>              # Direct download links from file (no search)

Options (search mode only, each at most once):
  -rl <res>    Resolution upper bound (not higher than), e.g. 1080p
  -rb <res>    Resolution lower bound (not lower than), e.g. 720p
  -zl <size>   Size upper bound (not larger than), suffixes k/m/g/t
  -zb <size>   Size lower bound (not smaller than), suffixes k/m/g/t

Options (search mode only, repeatable):
  -l [lang]    Audio language (ISO 639-1 code or full name).
               Without argument = original language (auto-detect via Wikidata)
  -t <lang>    Subtitle language (ISO 639-1 code or full name)

Examples:
  sator -s "Das Boot 1981" -l original -a
  sator -f movies.txt -l en -t ru -rb 720p -rl 1080p -zl 4g
  sator -a torrent.url
EOF
  exit 0
}

# ─── Size conversion ─────────────────────────────────────────────────────────
parse_size() {
  local val="$1"
  val=$(echo "$val" | tr '[:upper:]' '[:lower:]' | sed 's/[[:space:]]//g')
  if [[ "$val" =~ ^([0-9]+\.?[0-9]*)([kKmMgGtT]?)$ ]]; then
    local num="${BASH_REMATCH[1]}"
    local unit="${BASH_REMATCH[2]}"
    case "$unit" in
      k|K) echo "$(echo "$num * 1024" | bc -l | sed 's/\..*//')" ;;
      m|M) echo "$(echo "$num * 1024^2" | bc -l | sed 's/\..*//')" ;;
      g|G) echo "$(echo "$num * 1024^3" | bc -l | sed 's/\..*//')" ;;
      t|T) echo "$(echo "$num * 1024^4" | bc -l | sed 's/\..*//')" ;;
      *)   echo "$(echo "$num" | sed 's/\..*//')" ;;
    esac
  else
    echo ""
  fi
}

bytes_to_human() {
  local bytes="${1:-0}"
  if (( bytes >= 1024**4 )); then
    echo "$(echo "scale=1; $bytes / 1024^4" | bc) TiB"
  elif (( bytes >= 1024**3 )); then
    echo "$(echo "scale=1; $bytes / 1024^3" | bc) GiB"
  elif (( bytes >= 1024**2 )); then
    echo "$(echo "scale=1; $bytes / 1024^2" | bc) MiB"
  elif (( bytes >= 1024 )); then
    echo "$(echo "scale=1; $bytes / 1024" | bc) KiB"
  else
    echo "${bytes} B"
  fi
}

normalize_lang() {
  local input="$1"
  input=$(echo "$input" | tr '[:upper:]' '[:lower:]' | sed 's/[[:space:]]//g')
  if [[ "$input" =~ ^[a-z]{2}$ ]] && [[ -n "${LANG_NAMES[$input]:-}" ]]; then
    echo "$input"
  elif [[ -n "${LANG_CODES[$input]:-}" ]]; then
    echo "${LANG_CODES[$input]}"
  else
    echo ""
  fi
}

# ─── Wikidata original language lookup ────────────────────────────────────────
# Input: search query string
# Output: ISO 639-1 code or empty string
get_original_lang() {
  local query="$1"
  local sq
  sq=$(python3 -c "import urllib.parse; print(urllib.parse.quote('''$query'''))" 2>/dev/null)

  # Check cache
  if [[ -f "$WIKI_CACHE" ]]; then
    local cached
    cached=$(python3 -c "
import json, os
try:
    with open('$WIKI_CACHE') as f:
        d = json.load(f)
        print(d.get('$query', ''))
except: print('')
" 2>/dev/null)
    [[ -n "$cached" ]] && { echo "$cached"; return 0; }
  fi

  python3 -c "
import urllib.request, urllib.parse, json, os, sys

query = '''$query'''
cache_file = '$WIKI_CACHE'

try:
    # 1. Wikipedia search
    params = urllib.parse.urlencode({'action':'query','list':'search','srsearch':query+' film','format':'json','srlimit':1})
    req = urllib.request.Request('https://en.wikipedia.org/w/api.php?'+params, headers={'User-Agent':'sator/0.1'})
    resp = json.loads(urllib.request.urlopen(req,timeout=10).read())
    pages = resp.get('query',{}).get('search',[])
    if not pages: print(''); sys.exit(0)
    title = pages[0]['title']
except Exception: print(''); sys.exit(0)

try:
    # 2. Get wikibase ID
    params = urllib.parse.urlencode({'action':'query','prop':'pageprops','titles':title,'format':'json'})
    req = urllib.request.Request('https://en.wikipedia.org/w/api.php?'+params, headers={'User-Agent':'sator/0.1'})
    resp = json.loads(urllib.request.urlopen(req,timeout=10).read())
    eid = None
    for pid,pdata in resp.get('query',{}).get('pages',{}).items():
        if 'pageprops' in pdata and 'wikibase_item' in pdata['pageprops']:
            eid = pdata['pageprops']['wikibase_item']; break
    if not eid: print(''); sys.exit(0)
except Exception: print(''); sys.exit(0)

try:
    # 3. Get Wikidata entity
    req = urllib.request.Request('https://www.wikidata.org/wiki/Special:EntityData/'+eid+'.json', headers={'User-Agent':'sator/0.1'})
    resp = json.loads(urllib.request.urlopen(req,timeout=10).read())
    claims = resp.get('entities',{}).get(eid,{}).get('claims',{})
    lang_claim = claims.get('P364',[]) or claims.get('P407',[]) or claims.get('P2439',[])
    if not lang_claim: print(''); sys.exit(0)
    lang_q = lang_claim[0].get('mainsnak',{}).get('datavalue',{}).get('value',{}).get('id','')
    if not lang_q: print(''); sys.exit(0)
except Exception: print(''); sys.exit(0)

# Q-code to ISO 639-1 mapping
ISO_MAP = {
    'Q1860':'en','Q188':'de','Q12107':'ru','Q150':'fr','Q652':'it','Q1321':'es',
    'Q5146':'pt','Q7411':'nl','Q809':'pl','Q9027':'sv','Q9035':'da','Q1412':'fi',
    'Q9056':'cs','Q9067':'hu','Q7913':'ro','Q8798':'uk','Q9129':'el','Q9106':'tr',
    'Q9217':'th','Q9199':'vi','Q1568':'hi','Q9610':'bn','Q9288':'he','Q13955':'ar',
    'Q5287':'ja','Q9176':'ko','Q7855':'zh','Q9043':'no','Q9240':'id','Q9237':'ms',
    'Q9299':'sr','Q6654':'hr','Q9058':'sk','Q7914':'bg','Q9063':'sl','Q9083':'lt',
    'Q9052':'lv','Q9072':'et','Q294':'is','Q9142':'ga','Q9309':'cy','Q9166':'mt',
    'Q8748':'sq','Q9296':'mk','Q9301':'bs','Q7026':'ca','Q10134':'gl','Q8752':'eu','Q361':'la'
}
iso = ISO_MAP.get(lang_q, '')
if iso:
    print(iso)
    try:
        d = {}
        if os.path.exists(cache_file):
            with open(cache_file) as f: d = json.load(f)
        d[query] = iso
        os.makedirs(os.path.dirname(cache_file), exist_ok=True)
        with open(cache_file, 'w') as f: json.dump(d, f)
    except: pass
else:
    print('')
" 2>/dev/null || true
}

# ─── Nyaa.si search ──────────────────────────────────────────────────────────
search_nyaa() {
  local query="$1"
  local sq
  sq=$(python3 -c "import urllib.parse; print(urllib.parse.quote('''$query'''))" 2>/dev/null)
  local url="https://nyaa.si/?q=${sq}&f=0&c=0_0"
  local html
  html=$($CURL_BIN -s -L -A "$CURL_UA" --max-time 15 "$url" 2>/dev/null || true)
  [[ -z "$html" ]] && return 0

  echo "$html" | python3 -c '
import sys, re, json, html as htmlmod

data = sys.stdin.read()
rows = re.findall(r"<tr[^>]*>(.*?)</tr>", data, re.DOTALL)
results = []
for r in rows:
    if "<th" in r: continue
    tm = re.search(r"href=\"/view/\d+\"\s+title=\"([^\"]*)\"", r)
    if not tm: continue
    title = htmlmod.unescape(tm.group(1)).strip()
    mm = re.search(r"href=\"(magnet:[^\"]*)\"", r)
    if not mm: continue
    magnet = htmlmod.unescape(mm.group(1))
    sm = re.search(r"<td class=\"text-center\">([0-9.]+)\s*(KiB|MiB|GiB|TiB)\s*</td>", r)
    size_bytes = 0
    if sm:
        num = float(sm.group(1)); unit = sm.group(2)
        if unit == "TiB": size_bytes = int(num * 1024**4)
        elif unit == "GiB": size_bytes = int(num * 1024**3)
        elif unit == "MiB": size_bytes = int(num * 1024**2)
        elif unit == "KiB": size_bytes = int(num * 1024)
    tds = re.findall(r"<td class=\"text-center\">([^<]*)</td>", r)
    seeders = 0
    if len(tds) >= 6:
        try: seeders = int(tds[4].strip())
        except: seeders = 0
    results.append({"title": title, "magnet": magnet, "size_bytes": size_bytes, "seeders": seeders, "source": "nyaa"})
for r in results:
    print(json.dumps(r, ensure_ascii=False))
' 2>/dev/null || true
}

# ─── LimeTorrents search (may be blocked by Cloudflare) ──────────────────────
search_limetorrents() {
  local query="$1"
  local sq
  sq=$(python3 -c "import urllib.parse; print(urllib.parse.quote('''$query'''))" 2>/dev/null)
  local html

  # Try GET
  html=$($CURL_BIN -s -L -A "$CURL_UA" --max-time 15 "https://www.limetorrents.fun/search?q=${sq}" 2>/dev/null || true)
  if [[ -z "$html" ]] || grep -qi 'access denied\|just a moment\|cloudflare' <<< "$html" 2>/dev/null; then
    # Try POST
    html=$($CURL_BIN -s -L -A "$CURL_UA" -H "Content-Type: application/x-www-form-urlencoded" \
      -d "q=${sq}" --max-time 15 "https://www.limetorrents.fun/post/search.php" 2>/dev/null || true)
  fi
  [[ -z "$html" ]] && return 0
  if grep -qi 'access denied\|just a moment\|cloudflare' <<< "$html" 2>/dev/null; then
    return 0
  fi

  echo "$html" | python3 -c '
import sys, re, json, html as htmlmod

data = sys.stdin.read()
results = []
for m in re.finditer(r"<a\s+href=\"(/torrent/\d+/[^\"]*)\"\s+title=\"([^\"]*)\"", data):
    title = htmlmod.unescape(m.group(2)).strip()
    href = "https://www.limetorrents.fun" + m.group(1)
    results.append({"title": title, "magnet": "", "size_bytes": 0, "seeders": 0, "source": "limetorrents", "href": href})
    if len(results) > 30: break
for r in results:
    print(json.dumps(r, ensure_ascii=False))
' 2>/dev/null || true
}

# ─── Resolution filter ────────────────────────────────────────────────────────
get_resolution() {
  local title="$1"
  if grep -qi '2160p\|4k\|4[[:space:]]*k' <<< "$title"; then echo 2160
  elif grep -qi '1080p\|1080[^0-9]\|1[[:space:]]*080[^0-9]' <<< "$title"; then echo 1080
  elif grep -qi '720p\|720[^0-9]\|7[[:space:]]*20' <<< "$title"; then echo 720
  elif grep -qi '480p\|480[^0-9]\|dvd\|sd\|ntsc\|pal' <<< "$title"; then echo 480
  else echo 0; fi
}

# ─── Result filtering ─────────────────────────────────────────────────────────
filter_result() {
  local title="$1" size_bytes="$2"
  local res

  # Resolution upper bound
  if [[ -n "$RL" ]]; then
    case "$RL" in
      *2160*|*4k*|*4K*) res=2160 ;; *1080*|*FHD*) res=1080 ;;
      *720*|*HD*) res=720 ;; *480*|*SD*) res=480 ;; *) res=99999 ;;
    esac
    local fr=$(get_resolution "$title")
    (( fr > res )) && return 1
  fi

  # Resolution lower bound
  if [[ -n "$RB" ]]; then
    case "$RB" in
      *2160*|*4k*|*4K*) res=2160 ;; *1080*|*FHD*) res=1080 ;;
      *720*|*HD*) res=720 ;; *480*|*SD*) res=480 ;; *) res=0 ;;
    esac
    local fr=$(get_resolution "$title")
    (( fr != 0 && fr < res )) && return 1
  fi

  # Size upper bound
  if [[ -n "$ZL" ]] && (( ZL_BYTES > 0 && size_bytes > 0 && size_bytes > ZL_BYTES )); then
    return 1
  fi

  # Size lower bound
  if [[ -n "$ZB" ]] && (( ZB_BYTES > 0 && size_bytes > 0 && size_bytes < ZB_BYTES )); then
    return 1
  fi

  # Audio language filter (check title for language markers)
  if [[ ${#LANG_FILTERS[@]} -gt 0 ]]; then
    local has_lang=0
    for lc in "${LANG_FILTERS[@]}"; do
      local ln="${LANG_NAMES[$lc]:-}"
      grep -qi "\b${lc}\b" <<< "$title" 2>/dev/null && { has_lang=1; break; }
      [[ -n "$ln" ]] && grep -qi "\b${ln}\b" <<< "$title" 2>/dev/null && { has_lang=1; break; }
    done
    if (( has_lang == 0 )); then
      # If the title explicitly mentions a different language, reject
      grep -qi '\beng\b\|english\|rus\b\|russian\|fr\b\|french\|de\b\|german\|ita\b\|italian\|spa\b\|spanish\|jap\b\|japanese\|chi\b\|chinese\|kor\b\|korean\|por\b\|portuguese' <<< "$title" 2>/dev/null && return 1
    fi
  fi

  # Subtitle filter
  if [[ ${#SUBS_FILTERS[@]} -gt 0 ]]; then
    local has_subs=0
    for sc in "${SUBS_FILTERS[@]}"; do
      local sn="${LANG_NAMES[$sc]:-}"
      grep -qi "sub.*${sc}\|${sc}.*sub" <<< "$title" 2>/dev/null && { has_subs=1; break; }
      [[ -n "$sn" ]] && grep -qi "sub.*${sn}\|${sn}.*sub" <<< "$title" 2>/dev/null && { has_subs=1; break; }
    done
    # If no sub info found, pass (can't determine)
  fi

  return 0
}

# ─── qBittorrent API ─────────────────────────────────────────────────────────
qb_add() {
  local magnet="$1"
  [[ -z "$magnet" ]] && return 1
  local encoded
  encoded=$(echo "$magnet" | python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.stdin.read().strip()))' 2>/dev/null)
  [[ -z "$encoded" ]] && encoded="$magnet"
  curl -s -X POST "${QB_URL}/api/v2/torrents/add" \
    -d "urls=${encoded}" \
    --max-time 10 >/dev/null 2>&1 || true
}

# ═══════════════════════════════════════════════════════════════════════════════
# ARGUMENT PARSING
# ═══════════════════════════════════════════════════════════════════════════════

SEARCH_FILES=()
SEARCH_STRINGS=()
AUTO_ADD=0
AUTO_FILE=""
RL=""
RB=""
ZL=""
ZB=""
ZL_BYTES=0
ZB_BYTES=0
LANG_FILTERS=()
SUBS_FILTERS=()
HAS_ORIGINAL=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -f)
      [[ -z "${2:-}" ]] && { err "Missing argument for -f"; exit 1; }
      SEARCH_FILES+=("$2"); shift 2 ;;
    -s)
      [[ -z "${2:-}" ]] && { err "Missing argument for -s"; exit 1; }
      SEARCH_STRINGS+=("$2"); shift 2 ;;
    -a)
      if [[ -n "${2:-}" ]] && [[ "${2:0:1}" != "-" ]]; then
        AUTO_FILE="$2"; shift 2
      else
        AUTO_ADD=1; shift
      fi ;;
    -rl)
      [[ -z "${2:-}" ]] && { err "Missing argument for -rl"; exit 1; }
      [[ -n "$RL" ]] && { err "-rl already set (max once)"; exit 1; }
      RL="$2"; shift 2 ;;
    -rb)
      [[ -z "${2:-}" ]] && { err "Missing argument for -rb"; exit 1; }
      [[ -n "$RB" ]] && { err "-rb already set (max once)"; exit 1; }
      RB="$2"; shift 2 ;;
    -zl)
      [[ -z "${2:-}" ]] && { err "Missing argument for -zl"; exit 1; }
      [[ -n "$ZL" ]] && { err "-zl already set (max once)"; exit 1; }
      ZL="$2"; ZL_BYTES=$(parse_size "$2")
      [[ -z "$ZL_BYTES" ]] && { err "Invalid size: $2"; exit 1; }
      shift 2 ;;
    -zb)
      [[ -z "${2:-}" ]] && { err "Missing argument for -zb"; exit 1; }
      [[ -n "$ZB" ]] && { err "-zb already set (max once)"; exit 1; }
      ZB="$2"; ZB_BYTES=$(parse_size "$2")
      [[ -z "$ZB_BYTES" ]] && { err "Invalid size: $2"; exit 1; }
      shift 2 ;;
    -l)
      if [[ -z "${2:-}" ]] || [[ "${2:0:1}" == "-" ]]; then
        HAS_ORIGINAL=1; shift
      else
        n=$(normalize_lang "$2")
        if [[ -z "$n" ]]; then
          n=$(echo "$2" | tr '[:upper:]' '[:lower:]' | sed 's/[[:space:]]//g')
          if [[ "$n" == "or" ]] || [[ "$n" == "original" ]]; then
            HAS_ORIGINAL=1
          else
            err "Unknown language: $2"; exit 1
          fi
        else
          LANG_FILTERS+=("$n")
        fi
        shift 2
      fi ;;
    -t)
      [[ -z "${2:-}" ]] && { err "Missing argument for -t"; exit 1; }
      n=$(normalize_lang "$2")
      if [[ -z "$n" ]]; then
        err "Unknown language: $2"; exit 1
      fi
      SUBS_FILTERS+=("$n"); shift 2 ;;
    -h|--help) usage ;;
    *) err "Unknown: $1 (use -h)"; exit 1 ;;
  esac
done

# ═══════════════════════════════════════════════════════════════════════════════
# MODES
# ═══════════════════════════════════════════════════════════════════════════════

HAS_SEARCH=0
[[ ${#SEARCH_FILES[@]} -gt 0 || ${#SEARCH_STRINGS[@]} -gt 0 ]] && HAS_SEARCH=1

# No args → help
if [[ $HAS_SEARCH -eq 0 && -z "$AUTO_FILE" ]]; then
  usage
fi

# ─── Direct download mode ──────────────────────────────────────────────────────
if [[ $HAS_SEARCH -eq 0 && -n "$AUTO_FILE" ]]; then
  OTHER_KEYS=""
  [[ -n "$RL" ]] && OTHER_KEYS+=" -rl"
  [[ -n "$RB" ]] && OTHER_KEYS+=" -rb"
  [[ -n "$ZL" ]] && OTHER_KEYS+=" -zl"
  [[ -n "$ZB" ]] && OTHER_KEYS+=" -zb"
  [[ ${#LANG_FILTERS[@]} -gt 0 ]] && OTHER_KEYS+=" -l"
  [[ ${#SUBS_FILTERS[@]} -gt 0 ]] && OTHER_KEYS+=" -t"
  [[ $HAS_ORIGINAL -eq 1 ]] && OTHER_KEYS+=" -l"
  [[ -n "$OTHER_KEYS" ]] && warn "Direct download mode: ignoring${OTHER_KEYS}"

  [[ ! -f "$AUTO_FILE" ]] && { err "File not found: $AUTO_FILE"; exit 1; }

  ADDED=0
  while IFS= read -r line; do
    line=$(echo "$line" | sed 's/^[[:space:]]*//')
    [[ -z "$line" || "$line" =~ ^# ]] && continue
    if [[ "$line" =~ ^magnet: ]]; then
      qb_add "$line"
      ADDED=$((ADDED+1))
    fi
  done < "$AUTO_FILE"
  info "Added to qBittorrent: ${ADDED} links"
  exit 0
fi

# ═══════════════════════════════════════════════════════════════════════════════
# SEARCH MODE
# ═══════════════════════════════════════════════════════════════════════════════

QUERIES=()

for f in "${SEARCH_FILES[@]}"; do
  [[ ! -f "$f" ]] && { err "File not found: $f"; continue; }
  while IFS= read -r line; do
    line=$(echo "$line" | sed 's/^[[:space:]]*//')
    [[ -z "$line" ]] && continue
    [[ "$line" =~ ^# ]] && continue
    [[ "$line" =~ ^## ]] && continue
    [[ "$line" =~ ^--- ]] && continue
    [[ "$line" =~ ^[[:space:]]*$ ]] && continue
    # Extract year from line
    year=""
    if [[ "$line" =~ ([12][0-9]{3}) ]]; then
      year="${BASH_REMATCH[1]}"
    fi
    # Clean title
    cleaned=""
    if [[ "$line" =~ ^[0-9]+\. ]]; then
      # Format: N. **Title** — Year or N. **Title / TitleRu** — Year
      cleaned=$(echo "$line" | sed 's/^[0-9\.]*[[:space:]]*\*\*//' )
      cleaned=$(echo "$cleaned" | sed 's/\*\*.*//')
      cleaned=$(echo "$cleaned" | sed 's/[[:space:]]*—[[:space:]]*$//' | sed 's/[[:space:]]*$//')
      cleaned=$(echo "$cleaned" | sed 's/[[:space:]]*\/.*//')
    fi
    if [[ -z "$cleaned" ]]; then
      cleaned=$(echo "$line" | sed 's/^[-*]*[[:space:]]*//' | sed 's/[[:space:]]*$//')
    fi
    [[ -z "$cleaned" ]] && continue
    # Append year
    if [[ -n "$year" ]]; then
      cleaned="${cleaned} ${year}"
    fi
    QUERIES+=("$cleaned")
  done < "$f"
done

for s in "${SEARCH_STRINGS[@]}"; do
  QUERIES+=("$s")
done

mkdir -p "$CACHE_DIR"

# Wikidata language resolution
declare -A ORIG_LANG_MAP
if [[ $HAS_ORIGINAL -eq 1 ]]; then
  info "Resolving original languages via Wikidata..."
  for q in "${QUERIES[@]}"; do
    [[ -n "${ORIG_LANG_MAP[$q]:-}" ]] && continue
    lang=$(get_original_lang "$q")
    if [[ -n "$lang" ]]; then
      ORIG_LANG_MAP["$q"]="$lang"
      info "[$q] → ${lang} (${LANG_NAMES[$lang]:-})"
    else
      ORIG_LANG_MAP["$q"]=""
      warn "[$q] → could not determine original language, no filter applied"
    fi
  done
fi

# ─── Tracker search loop ───────────────────────────────────────────────────────
TOTAL=${#QUERIES[@]}
FOUND_COUNT=0
NOT_FOUND_ITEMS=()
FILTERED_OUT_ITEMS=()
ALL_MAGNETS=""
TOTAL_SIZE=0
ADDED_COUNT=0
START_TIME=$(date +%s)

for i in "${!QUERIES[@]}"; do
  q="${QUERIES[$i]}"
  num=$((i + 1))

  echo "[${num}/${TOTAL}] ${q}"

  # Collect language filters (user + original)
  CURRENT_LANG_FILTERS=("${LANG_FILTERS[@]}")
  if [[ -n "${ORIG_LANG_MAP[$q]:-}" ]]; then
    CURRENT_LANG_FILTERS+=("${ORIG_LANG_MAP[$q]}")
  fi

  # Temporarily override LANG_FILTERS
  LANG_FILTERS=("${CURRENT_LANG_FILTERS[@]}")

  TRACKER_RESULTS=""
  # Nyaa.si
  NYAA_OUT=$(search_nyaa "$q")
  [[ -n "$NYAA_OUT" ]] && TRACKER_RESULTS+="$NYAA_OUT"$'\n'

  # LimeTorrents (if accessible)
  LT_OUT=$(search_limetorrents "$q")
  [[ -n "$LT_OUT" ]] && TRACKER_RESULTS+="$LT_OUT"$'\n'

  # Parse and filter results
  FOUND_ANY=0

  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    title=$(echo "$line" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('title',''))" 2>/dev/null || true)
    magnet=$(echo "$line" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('magnet',''))" 2>/dev/null || true)
    sb=$(echo "$line" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('size_bytes',0))" 2>/dev/null || true)
    sd=$(echo "$line" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('seeders',0))" 2>/dev/null || true)
    src=$(echo "$line" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('source',''))" 2>/dev/null || true)
    [[ -z "$title" ]] && continue

    if filter_result "$title" "$sb"; then
      FOUND_ANY=1
      FOUND_COUNT=$((FOUND_COUNT+1))
      sh=$(bytes_to_human "$sb")
      echo "  ✓ ${title} (${sh}) [${src}] 🧲:${sd}"
      [[ -n "$magnet" ]] && echo "    ${magnet}"
      ALL_MAGNETS+="$magnet"$'\n'
      TOTAL_SIZE=$((TOTAL_SIZE + sb))
      [[ $AUTO_ADD -eq 1 && -n "$magnet" ]] && { qb_add "$magnet"; ADDED_COUNT=$((ADDED_COUNT+1)); }
    else
      FILTERED_OUT_ITEMS+=("$title")
    fi
  done <<< "$(echo "$TRACKER_RESULTS" | python3 -c "
import sys, json
data = sys.stdin.read().strip()
if not data: sys.exit(0)
for line in data.split('\n'):
    line = line.strip()
    if line: print(line)
" 2>/dev/null)"

  if [[ $FOUND_ANY -eq 0 ]]; then
    echo "  ✗ Not found"
    NOT_FOUND_ITEMS+=("$q")
  fi

  echo ""
done

# ═══════════════════════════════════════════════════════════════════════════════
# FINAL REPORT
# ═══════════════════════════════════════════════════════════════════════════════

END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

echo "Report:"
echo "  Found:        ${FOUND_COUNT}"
echo "  Not found:    ${#NOT_FOUND_ITEMS[@]}"
echo "  Filtered out: ${#FILTERED_OUT_ITEMS[@]}"
if [[ $AUTO_ADD -eq 1 ]]; then
  echo "  Added to QB:  ${ADDED_COUNT} ($(bytes_to_human "$TOTAL_SIZE"))"
fi
echo "  Time:         $((DURATION / 60))m $((DURATION % 60))s"

# Output magnet links to stdout (without -a)
if [[ $AUTO_ADD -eq 0 ]]; then
  echo "$ALL_MAGNETS"
fi
